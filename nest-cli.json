{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": "resources/certificatesConfig/assets/**/*",
        "outDir": "dist/src",
        "watchAssets": true
      },
      { 
        "include": "**/*.ttf", 
        "outDir": "dist/src",
        "watchAssets": true
      }
    ]
  }
}